model Model
	culture: pt-BR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["DimTempo","FatoSerieMensal","Regional","Segmento","Setor","FunilAprovacao","FaixasRisco","OperacaoDiaria","_Medidas"]

annotation __PBI_TimeIntelligenceEnabled = 1

ref table DimTempo
ref table FatoSerieMensal
ref table Regional
ref table Segmento
ref table Setor
ref table FunilAprovacao
ref table FaixasRisco
ref table OperacaoDiaria
ref table _Medidas

ref culture pt-BR
